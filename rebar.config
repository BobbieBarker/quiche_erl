{erl_opts, [debug_info, warnings_as_errors]}.

{pre_hooks, [
    {"(linux|darwin)", compile, "make -C c_src"},
    {"(linux|darwin)", clean, "make -C c_src clean"}
]}.

{project_plugins, [
    erlfmt,
    rebar3_ex_doc,
    rebar3_hex
]}.

{erlfmt, [write]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    {source_url, <<"https://github.com/BobbieBarker/quiche_erl">>},
    {extras, [<<"README.md">>, <<"LICENSE">>]},
    {main, <<"README.md">>}
]}.

{dialyzer, [
    {warnings, [error_handling, underspecs, unmatched_returns, unknown]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]},
        {erl_opts, [nowarn_export_all]}
    ]}
]}.
